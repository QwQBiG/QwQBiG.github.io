---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import FloatingNavCard from '../components/FloatingNavCard.astro';

const pageTitle = "搜索 - QwQBiG's World";
const pageDescription = "搜索博客文章";
---

<Layout title={pageTitle} description={pageDescription}>
  <FloatingNavCard />
  
  <main class="flex-1 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Page Header -->
      <div class="text-center mb-12">
        <h1 class="font-sans font-bold text-3xl md:text-4xl text-text-primary mb-4">
          🔍 搜索
        </h1>
        <p class="font-sans text-lg text-text-secondary">
          输入关键词搜索文章
        </p>
      </div>

      <!-- Search Input -->
      <div class="search-input-wrapper">
        <svg class="search-input-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <input 
          type="text" 
          id="search-input"
          class="search-input"
          placeholder="输入关键词..."
          autocomplete="off"
        />
      </div>

      <!-- Search Results -->
      <div id="search-results" class="search-results">
        <div class="text-center text-text-muted py-12">
          输入关键词开始搜索
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  // Simple client-side search
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');
  
  let posts: Array<{
    title: string;
    description?: string;
    slug: string;
    collection: string;
    date: string;
    tags: string[];
  }> = [];
  
  // Load posts data
  async function loadPosts() {
    try {
      const response = await fetch('/posts.json');
      posts = await response.json();
    } catch (error) {
      console.error('Failed to load posts:', error);
    }
  }
  
  // Search function
  function search(query: string) {
    if (!query.trim()) {
      searchResults!.innerHTML = `
        <div class="text-center text-text-muted py-12">
          输入关键词开始搜索
        </div>
      `;
      return;
    }
    
    const lowerQuery = query.toLowerCase();
    const results = posts.filter(post => 
      post.title.toLowerCase().includes(lowerQuery) ||
      post.description?.toLowerCase().includes(lowerQuery) ||
      post.tags?.some(tag => tag.toLowerCase().includes(lowerQuery))
    );
    
    if (results.length === 0) {
      searchResults!.innerHTML = `
        <div class="text-center text-text-muted py-12">
          没有找到相关文章
        </div>
      `;
      return;
    }
    
    searchResults!.innerHTML = results.map(post => `
      <a href="/${post.collection}/${post.slug}/" class="search-result-item block">
        <h3 class="search-result-title">${highlightMatch(post.title, query)}</h3>
        ${post.description ? `<p class="search-result-excerpt">${highlightMatch(post.description, query)}</p>` : ''}
        <div class="search-result-meta">
          <span>${post.date}</span>
          ${post.tags?.length ? `<span>${post.tags.slice(0, 3).join(', ')}</span>` : ''}
        </div>
      </a>
    `).join('');
  }
  
  // Highlight matching text
  function highlightMatch(text: string, query: string): string {
    const regex = new RegExp(`(${escapeRegex(query)})`, 'gi');
    return text.replace(regex, '<mark class="bg-primary/20 text-primary px-1 rounded">$1</mark>');
  }
  
  function escapeRegex(string: string): string {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }
  
  // Debounce function
  function debounce<T extends (...args: any[]) => void>(func: T, wait: number) {
    let timeout: ReturnType<typeof setTimeout>;
    return (...args: Parameters<T>) => {
      clearTimeout(timeout);
      timeout = setTimeout(() => func(...args), wait);
    };
  }
  
  // Event listeners
  const debouncedSearch = debounce(search, 300);
  
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value;
    debouncedSearch(query);
  });
  
  // Initialize
  loadPosts();
</script>
