                </svg>
              </a>
            </div>
          </GlassCard>
        </div>
        
        <!-- 日历 - 移动端第10，桌面端右中靠右 -->
        <div class="order-10 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-3 [@media(min-width:924px)]:row-start-2 [@media(min-width:924px)]:place-self-end [@media(min-width:924px)]:self-center [@media(min-width:924px)]:-translate-x-24 [@media(min-width:924px)]:translate-y-0">
          <GlassCard padding="small" tilt={true} class="w-full [@media(min-width:924px)]:w-auto [@media(min-width:924px)]:scale-95">
            <CalendarWidget />
          </GlassCard>
        </div>
        
        <!-- ========== 第3行 ========== -->
        
        <!-- 常用标签 - 移动端第8，桌面端左下靠右上 -->
        <div class="order-8 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-1 [@media(min-width:924px)]:row-start-3 [@media(min-width:924px)]:place-self-start [@media(min-width:924px)]:self-end [@media(min-width:924px)]:translate-x-32 [@media(min-width:924px)]:-translate-y-32">
          <GlassCard padding="small" tilt={true} class="w-full [@media(min-width:924px)]:max-w-xs [@media(min-width:924px)]:scale-90">
            <div class="flex flex-col">
              <h3 class="text-sm font-bold text-gray-700 mb-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
                常用标签
              </h3>
              <div class="flex flex-wrap gap-1.5">
                {Array.from(new Set(regularPosts.flatMap(p => p.data.tags || []))).slice(0, 8).map((tag) => (
                  <a href={`/tags/${tag}/`} class="tag">
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          </GlassCard>
        </div>
        
        <!-- 音乐播放器 - 移动端第3，桌面端中下靠上偏右 -->
        <div class="order-3 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-2 [@media(min-width:924px)]:row-start-3 [@media(min-width:924px)]:place-self-start [@media(min-width:924px)]:self-center [@media(min-width:924px)]:translate-x-0 [@media(min-width:924px)]:-translate-y-8">
          <GlassCard padding="small" tilt={true} class="w-full [@media(min-width:924px)]:max-w-md [@media(min-width:924px)]:scale-95">
            <MusicWidget />
          </GlassCard>
        </div>
        
        <!-- 最新文章 - 移动端第9，桌面端右下靠左上 -->
        <div class="order-9 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-3 [@media(min-width:924px)]:row-start-3 [@media(min-width:924px)]:place-self-start [@media(min-width:924px)]:self-start [@media(min-width:924px)]:-translate-x-8 [@media(min-width:924px)]:-translate-y-32">
          <GlassCard padding="medium" tilt={true} class="w-full [@media(min-width:924px)]:max-w-xs [@media(min-width:924px)]:scale-95">
            <div class="flex flex-col h-full">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-bold text-gray-700 flex items-center gap-2">
                  <svg class="w-4 h-4 text-purple-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  最新文章
                </h3>
                <a href="/cs/" class="text-xs text-purple-600 hover:text-purple-700">全部 →</a>
              </div>
              {latestPosts.slice(0, 1).map((post) => (
                <a href={`/cs/${post.slug}/`} class="post-item block group flex-1">
                  <div class="flex flex-col h-full">
                    <h4 class="text-base font-semibold text-gray-800 group-hover:text-purple-600 transition-colors leading-snug mb-2">
                      {post.data.title}
                    </h4>
                    <p class="text-xs text-gray-500 line-clamp-2 mb-3 flex-1">
                      {post.data.description || '暂无摘要'}
                    </p>
                    <div class="flex items-center justify-between pt-2 border-t border-gray-200/50">
                      <span class="text-[10px] text-gray-400">
                        {post.data.date.toLocaleDateString('zh-CN')}
                      </span>
                      <span class="text-[10px] text-purple-500 group-hover:translate-x-1 transition-transform">
                        阅读 →
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </GlassCard>
        </div>
        
      </div>
      <!-- /grid -->
      
    </div>
  </div>
</body>
</html>
