---
import GlassCard from '../components/GlassCard.astro';
import ParticleLifeCore from '../components/ParticleLifeCore.jsx';
import ClockWidget from '../components/ClockWidget.astro';
import CalendarWidget from '../components/CalendarWidget.astro';
import MusicWidget from '../components/MusicWidget.astro';
import { getCollection } from 'astro:content';

// Get all posts from CS collection
const csPosts = await getCollection('cs', ({ data }) => !data.draft);

// Get all series from _index.md files
const seriesEntries = csPosts.filter(post => post.slug.endsWith('/_index') || post.slug.endsWith('_index'));

// Get regular posts (not series index pages)
const regularPosts = csPosts.filter(post => 
  !post.slug.endsWith('/_index') && !post.slug.endsWith('_index')
);

// Sort posts by date (newest first)
const sortedPosts = regularPosts.sort((a, b) => 
  b.data.date.getTime() - a.data.date.getTime()
);

// Get pinned series
const pinnedSeries = seriesEntries
  .filter(entry => entry.data.pin)
  .map(entry => {
    const seriesName = entry.data.title;
    const seriesSlug = entry.slug.replace('/_index', '').replace('_index', '');
    const postCount = regularPosts.filter(post => 
      post.data.series?.includes(seriesName)
    ).length;
    
    return {
      title: entry.data.title,
      description: entry.data.description,
      slug: seriesSlug,
      postCount,
    };
  });

// Get latest 3 posts
const latestPosts = sortedPosts.slice(0, 3);

// Stats
const totalPosts = regularPosts.length;
const totalSeries = pinnedSeries.length;
const totalTags = new Set(regularPosts.flatMap(p => p.data.tags || [])).size;
const yearsActive = new Date().getFullYear() - 2024;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QwQBiG's World</title>
  <meta name="description" content="计算机科学学习笔记 | 算法 | 编程 | 嵌入式开发">
  <link rel="icon" type="image/png" href="/ZhenXun.png">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap');
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }
    
    .gradient-bg {
      background: linear-gradient(
        135deg,
        rgb(205, 180, 219) 0%,
        rgb(255, 200, 221) 25%,
        rgb(255, 175, 204) 50%,
        rgb(189, 224, 254) 75%,
        rgb(162, 210, 255) 100%
      );
      background-size: 400% 400%;
      animation: gradientShift 15s ease infinite;
    }
    
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    
    /* 标签样式 */
    .tag {
      display: inline-block;
      padding: 0.25rem 0.625rem;
      background: rgba(255, 255, 255, 0.5);
      border-radius: 9999px;
      font-size: clamp(0.625rem, 1.2vw, 0.75rem);
      color: #4a5568;
      transition: all 0.2s;
      white-space: nowrap;
    }
    
    .tag:hover {
      background: rgba(255, 255, 255, 0.8);
      transform: translateY(-1px);
    }
    
    /* 文章卡片 */
    .post-item {
      padding: 0.5rem 0.625rem;
      border-radius: 0.625rem;
      background: rgba(255, 255, 255, 0.3);
      transition: all 0.2s;
    }
    
    .post-item:hover {
      background: rgba(255, 255, 255, 0.5);
    }
    
    /* 链接样式 */
    .nav-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.375rem 0.5rem;
      border-radius: 0.75rem;
      color: #4a5568;
      text-decoration: none;
      transition: all 0.2s;
      font-size: clamp(0.75rem, 1.5vw, 0.875rem);
    }
    
    .nav-link:hover {
      background: rgba(255, 255, 255, 0.5);
      color: #2d3748;
    }
    
    /* 统计数字 */
    .stat-number {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      font-weight: 700;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.2;
    }
    
    /* 滚动条样式 */
    ::-webkit-scrollbar {
      width: 6px;
    }
    
    ::-webkit-scrollbar-track {
      background: transparent;
    }
    
    ::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.5);
      border-radius: 3px;
    }
    
    /* 欢迎卡片大偏移 */
    @media (min-width: 924px) {
      .welcome-card-offset {
        transform: translateX(22rem) translateY(6rem) !important;
      }
    }
  </style>
</head>
<body class="gradient-bg">
  <!-- 外层包装器 - 确保内容在屏幕绝对正中心 -->
  <div class="min-h-screen w-full flex items-center justify-center overflow-hidden py-6 [@media(min-width:924px)]:py-8 px-4 sm:px-6 [@media(min-width:924px)]:px-12 xl:px-12">
