---
import GlassCard from '../components/ui/GlassCard.astro';
import AnimeCore from '../components/3d/AnimeCore.tsx';
import ClockWidget from '../components/widgets/ClockWidget.astro';
import CalendarWidget from '../components/widgets/CalendarWidget.astro';
import MusicWidget from '../components/widgets/MusicWidget.astro';
import { getCollection } from 'astro:content';

// Get all posts from CS collection
const csPosts = await getCollection('cs', ({ data }) => !data.draft);

// 识别合集：slug 只包含一个斜杠（格式为 posts/xxx）且 id 包含 index.md
const seriesEntries = csPosts.filter(post => {
  const slashCount = (post.slug.match(/\//g) || []).length;
  return slashCount === 1 && post.id.includes('index.md');
});

// Get regular posts（包含两个斜杠的文章，即子目录中的文章）
const regularPosts = csPosts.filter(post => {
  const slashCount = (post.slug.match(/\//g) || []).length;
  return slashCount >= 2;
});

// Sort posts by date (newest first)
const sortedPosts = regularPosts.sort((a, b) => 
  b.data.date.getTime() - a.data.date.getTime()
);

// Get pinned series
const pinnedSeries = seriesEntries
  .filter(entry => entry.data.pin)
  .map(entry => {
    const seriesName = entry.data.title;
    const seriesSlug = entry.slug;
    const postCount = regularPosts.filter(post => 
      post.data.series?.includes(seriesName)
    ).length;
    
    return {
      title: entry.data.title,
      description: entry.data.description,
      slug: seriesSlug,
      postCount,
    };
  });

// Get latest 3 posts
const latestPosts = sortedPosts.slice(0, 3);

// Stats
const totalPosts = regularPosts.length;
const totalSeries = seriesEntries.length;
const totalTags = new Set(regularPosts.flatMap(p => p.data.tags || [])).size;
const yearsActive = new Date().getFullYear() - 2024;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QwQBiG's World</title>
  <meta name="description" content="CS Learning Notes | Algorithms | Programming | Embedded Development">
  <link rel="icon" type="image/png" href="/ZhenXun.png">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Quicksand:wght@300;400;500;600;700&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Quicksand', -apple-system, BlinkMacSystemFont, sans-serif;
      /* 使用 dvh 单位避免移动端地址栏影响 */
      min-height: 100dvh;
      min-height: 100vh; /* 回退 */
      overflow-x: hidden;
      /* 全局禁用文本光标和选择 */
      caret-color: transparent;
      user-select: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      /* 移动端优化：防止文本缩放 */
      -webkit-text-size-adjust: 100%;
      text-size-adjust: 100%;
      /* GPU 加速 */
      transform: translateZ(0);
    }

    /* 移动端触摸优化 */
    @media (hover: none) and (pointer: coarse) {
      * {
        /* 禁用移动端双击缩放 */
        touch-action: manipulation;
      }
      
      /* 移动端减少动画复杂度 */
      .gradient-bg {
        animation-duration: 20s;
      }
      
      /* 移动端优化滚动 */
      .min-h-screen {
        -webkit-overflow-scrolling: touch;
        min-height: 100dvh;
      }
    }
    
    .gradient-bg {
      background: linear-gradient(
        135deg,
        rgb(205, 180, 219) 0%,
        rgb(255, 200, 221) 25%,
        rgb(255, 175, 204) 50%,
        rgb(189, 224, 254) 75%,
        rgb(162, 210, 255) 100%
      );
      background-size: 400% 400%;
      animation: gradientShift 15s ease infinite;
    }
    
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* 全局性能优化 */
    * {
      /* 启用 GPU 加速 */
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* 减少动画偏好设置支持 */
    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
    
    /* 呼吸感 3D 球体样式 */
    .breathing-sphere {
      /* 多层渐变背景模拟球体体积感 */
      background: 
        radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.4) 20%, transparent 50%),
        radial-gradient(circle at 70% 70%, rgba(192, 132, 252, 0.4) 0%, rgba(236, 72, 153, 0.2) 40%, transparent 70%),
        linear-gradient(135deg, rgba(219, 180, 255, 0.3) 0%, rgba(255, 180, 220, 0.3) 50%, rgba(180, 220, 255, 0.3) 100%);
      
      /* 3D 球体阴影效果 */
      box-shadow: 
        /* 外层弥散阴影 */
        0 20px 60px -10px rgba(147, 51, 234, 0.3),
        0 30px 80px -15px rgba(236, 72, 153, 0.25),
        0 40px 100px -20px rgba(59, 130, 246, 0.2),
        /* 内层高光 */
        inset -10px -10px 30px rgba(147, 51, 234, 0.15),
        inset 10px 10px 30px rgba(255, 255, 255, 0.6),
        /* 边缘光晕 */
        0 0 0 1px rgba(255, 255, 255, 0.4),
        0 0 30px rgba(192, 132, 252, 0.2);
      
      /* 呼吸动画 */
      animation: breathe 4s ease-in-out infinite;
      
      /* 3D 变换 */
      transform-style: preserve-3d;
      perspective: 1000px;
    }
    
    @keyframes breathe {
      0%, 100% {
        transform: scale(1) translateZ(0);
        box-shadow: 
          0 20px 60px -10px rgba(147, 51, 234, 0.3),
          0 30px 80px -15px rgba(236, 72, 153, 0.25),
          0 40px 100px -20px rgba(59, 130, 246, 0.2),
          inset -10px -10px 30px rgba(147, 51, 234, 0.15),
          inset 10px 10px 30px rgba(255, 255, 255, 0.6),
          0 0 0 1px rgba(255, 255, 255, 0.4),
          0 0 30px rgba(192, 132, 252, 0.2);
      }
      50% {
        transform: scale(1.03) translateZ(10px);
        box-shadow: 
          0 25px 70px -8px rgba(147, 51, 234, 0.35),
          0 35px 90px -12px rgba(236, 72, 153, 0.3),
          0 45px 110px -18px rgba(59, 130, 246, 0.25),
          inset -12px -12px 35px rgba(147, 51, 234, 0.2),
          inset 12px 12px 35px rgba(255, 255, 255, 0.7),
          0 0 0 1px rgba(255, 255, 255, 0.5),
          0 0 40px rgba(192, 132, 252, 0.3);
      }
    }
    
    /* 标签样式 */
    .tag {
      display: inline-block;
      padding: 0.25rem 0.625rem;
      background: rgba(255, 255, 255, 0.5);
      border-radius: 9999px;
      font-size: clamp(0.625rem, 1.2vw, 0.75rem);
      color: #4a5568;
      transition: all 0.2s;
      white-space: nowrap;
      /* 禁用光标和选择 */
      caret-color: transparent;
      user-select: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
    }

    .tag:hover {
      background: rgba(255, 255, 255, 0.8);
      transform: translateY(-1px);
    }

    /* 文章卡片 */
    .post-item {
      padding: 0.5rem 0.625rem;
      border-radius: 0.625rem;
      background: rgba(255, 255, 255, 0.3);
      transition: all 0.2s;
      /* 禁用光标和选择 */
      caret-color: transparent;
      user-select: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
    }

    .post-item:hover {
      background: rgba(255, 255, 255, 0.5);
    }

    /* 链接样式 */
    .nav-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.375rem 0.5rem;
      border-radius: 0.75rem;
      color: #4a5568;
      text-decoration: none;
      transition: all 0.2s;
      font-size: clamp(0.75rem, 1.5vw, 0.875rem);
      /* 禁用光标和选择 */
      caret-color: transparent;
      user-select: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
    }

    .nav-link:hover {
      background: rgba(255, 255, 255, 0.5);
      color: #2d3748;
    }

    /* 统计数字 */
    .stat-number {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      font-weight: 700;
      /* 禁用光标和选择 */
      caret-color: transparent;
      user-select: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.2;
    }
    
    /* 滚动条样式 */
    ::-webkit-scrollbar {
      width: 6px;
    }
    
    ::-webkit-scrollbar-track {
      background: transparent;
    }
    
    ::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.5);
      border-radius: 3px;
    }
    
    /* 欢迎卡片大偏移 */
    @media (min-width: 924px) {
      .welcome-card-offset {
        transform: translateX(22rem) translateY(6rem) !important;
      }
    }
    

    
    @keyframes pulseRing {
      0%, 100% {
        opacity: 0.2;
        transform: scale(1);
      }
      50% {
        opacity: 0.4;
        transform: scale(1.02);
      }
    }
    
    .floating-ring {
      transition: transform 0.3s ease-out;
    }
    
    /* 环形文字交互3D倾斜效果 */
    .floating-ring {
      --rotateX: 0deg;
      --rotateY: 0deg;
      --translateZ: 0px;
      transform: perspective(1000px) rotateX(var(--rotateX)) rotateY(var(--rotateY)) translateZ(var(--translateZ));
    }
    

    
    /* 环形文字内层旋转 */
    @keyframes textRotate {
      0% {
        transform: rotate(0deg);
      }
      100% {
        transform: rotate(360deg);
      }
    }
    
    .ring-text-rotate {
      animation: textRotate 30s linear infinite;
      transform-origin: center;
    }
    
    .ring-text-rotate:hover {
      animation-play-state: paused;
    }
    
    /* 导航栏优雅动效 - 流畅的位置移动 + 弹性布局转换 */

    /* GPU 加速优化 */
    .gpu-accelerated {
      transform: translateZ(0);
      backface-visibility: hidden;
      perspective: 1000px;
    }

    /* 阶段1：位置移动动画 - 流畅斜向移动到左上角 */
    .nav-card-moving {
      /* 使用 will-change 优化性能 */
      will-change: transform, opacity;
      /* 更流畅的缓动曲线 - 使用更平滑的贝塞尔曲线 */
      transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease-out;
      /* GPU 加速 */
      transform: translateZ(0);
    }

    /* GlassCard padding 动画 - 从 p-5 (1.25rem) 到 p-3 (0.75rem)，与 FloatingNavCard 一致 */
    #navCard.nav-card-layout-change .glass-card {
      animation: navCardPadding 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      will-change: padding;
    }

    @keyframes navCardPadding {
      0% { padding: 1.25rem; }
      50% { padding: 0.6rem; }
      100% { padding: 0.75rem; }
    }

    /* 阶段2：布局转换动画 - 弹性效果 - 优化后的更流畅版本 */
    .nav-card-layout-change .nav-container {
      animation: navLayoutElastic 0.65s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      will-change: flex-direction, gap;
    }

    @keyframes navLayoutElastic {
      0% {
        flex-direction: column;
        gap: 1rem;
      }
      35% {
        /* 过渡状态，开始压缩 */
        flex-direction: column;
        gap: 0.3rem;
      }
      55% {
        /* 弹性过冲 */
        flex-direction: row;
        gap: 0.7rem;
      }
      75% {
        /* 回弹 */
        flex-direction: row;
        gap: 0.35rem;
      }
      100% {
        flex-direction: row;
        gap: 0.5rem;
      }
    }
    
    /* 头像弹性缩放 - 从 56px/64px 到 32px (2rem)，与 FloatingNavCard 一致 - 优化版本 */
    .nav-card-layout-change .nav-avatar {
      animation: navAvatarElastic 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      will-change: width, height, transform;
    }

    @keyframes navAvatarElastic {
      0% {
        width: 3.5rem;
        height: 3.5rem;
        transform: rotate(0deg) scale(1);
      }
      25% {
        /* 准备 */
        width: 3.5rem;
        height: 3.5rem;
        transform: rotate(-8deg) scale(1.05);
      }
      45% {
        /* 弹性过冲 */
        width: 2.2rem;
        height: 2.2rem;
        transform: rotate(4deg) scale(0.95);
      }
      65% {
        /* 回弹 */
        width: 1.95rem;
        height: 1.95rem;
        transform: rotate(-1deg) scale(1.02);
      }
      100% {
        width: 2rem;
        height: 2rem;
        transform: rotate(0deg) scale(1);
      }
    }

    /* 头像图片圆角动画 - 最终 rounded-lg (0.5rem) */
    .nav-card-layout-change .nav-avatar img {
      animation: navAvatarRadius 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
    }

    @keyframes navAvatarRadius {
      0% { border-radius: 0.75rem; }
      100% { border-radius: 0.5rem; }
    }

    /* 在线状态指示器大小动画 - 从 14px 到 10px (w-2.5 h-2.5)，与 FloatingNavCard 一致 */
    .nav-card-layout-change .nav-avatar .absolute {
      animation: navStatusElastic 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
    }

    @keyframes navStatusElastic {
      0% {
        width: 0.875rem;
        height: 0.875rem;
      }
      100% {
        width: 0.625rem;
        height: 0.625rem;
      }
    }
    
    /* 导航链接列表弹性转换 - 只作用于导航栏内的链接 - 优化版本 */
    #navCard.nav-card-layout-change .nav-links {
      animation: navLinksElastic 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      will-change: flex-direction, gap, opacity;
    }

    @keyframes navLinksElastic {
      0% {
        flex-direction: column;
        gap: 0.5rem;
        opacity: 1;
      }
      25% {
        flex-direction: column;
        gap: 0.15rem;
        opacity: 0.85;
      }
      45% {
        flex-direction: row;
        gap: 0.4rem;
        opacity: 0.92;
      }
      100% {
        flex-direction: row;
        gap: 0.25rem;
        opacity: 1;
      }
    }

    /* 导航链接项弹性变形 - 最终 2rem x 2rem 正方形，无文字，与 FloatingNavCard 一致 - 优化版本 */
    #navCard.nav-card-layout-change .nav-link {
      animation: navLinkElastic 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      will-change: width, height, padding, border-radius, transform;
    }

    @keyframes navLinkElastic {
      0% {
        width: auto;
        height: auto;
        padding: 0.5rem 1rem;
        border-radius: 0.75rem;
        transform: translateX(0) scale(1);
      }
      25% {
        /* 准备收缩 */
        width: auto;
        height: auto;
        padding: 0.35rem 0.5rem;
        border-radius: 0.6rem;
        transform: translateX(-4px) scale(0.98);
      }
      45% {
        /* 弹性过冲 */
        width: 2.2rem;
        height: 2.2rem;
        padding: 0;
        border-radius: 0.55rem;
        transform: translateX(2px) scale(1.03);
      }
      65% {
        /* 回弹 */
        width: 1.95rem;
        height: 1.95rem;
        transform: translateX(-1px) scale(0.99);
      }
      100% {
        width: 2rem;
        height: 2rem;
        padding: 0;
        border-radius: 0.5rem;
        justify-content: center;
        transform: translateX(0) scale(1);
      }
    }

    /* 导航链接文字优雅淡出 - 只作用于导航栏内的链接 */
    #navCard.nav-card-layout-change .nav-link span {
      animation: navTextFade 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    @keyframes navTextFade {
      0% {
        opacity: 1;
        max-width: 100px;
        margin-left: 0.5rem;
        transform: translateY(0);
      }
      50% {
        opacity: 0.5;
        max-width: 50px;
        margin-left: 0.25rem;
        transform: translateY(-3px);
      }
      100% {
        opacity: 0;
        max-width: 0;
        margin-left: 0;
        transform: translateY(-5px);
        display: none;
      }
    }
    
    /* 整体容器微光效果 */
    .nav-card-moving .glass-card {
      animation: navGlowPulse 0.7s ease-out;
    }
    
    @keyframes navGlowPulse {
      0% {
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.15), 0 40px 60px -20px rgba(0, 0, 0, 0.1), inset 0 1px 1px 0 rgba(255, 255, 255, 0.7);
      }
      50% {
        box-shadow: 0 30px 60px -15px rgba(139, 92, 246, 0.3), 0 50px 80px -20px rgba(139, 92, 246, 0.2), inset 0 1px 1px 0 rgba(255, 255, 255, 0.9), 0 0 30px rgba(139, 92, 246, 0.4);
      }
      100% {
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.15), 0 40px 60px -20px rgba(0, 0, 0, 0.1), inset 0 1px 1px 0 rgba(255, 255, 255, 0.7);
      }
    }
    
    /* 页面其他元素淡出 */
    .page-fade-out {
      animation: fadeOut 0.4s ease-out forwards;
    }
    
    @keyframes fadeOut {
      to {
        opacity: 0;
        transform: scale(0.98);
      }
    }
  </style>
</head>
<body class="gradient-bg">
  <!-- 外层包装器 - 始终居中 -->
  <div class="min-h-screen w-full flex items-center justify-center overflow-hidden py-6 [@media(min-width:924px)]:py-8 px-4 sm:px-6 [@media(min-width:924px)]:px-12 xl:px-12">
    <!-- 网格容器 - 由外层 flex 推到屏幕中心 -->
    <div class="flex flex-col [@media(min-width:924px)]:grid [@media(min-width:924px)]:grid-cols-3 gap-6 [@media(min-width:924px)]:gap-10 relative">

        <!-- ========== 移动端第1个 / 桌面端左上 ========== -->

        <!-- 欢迎卡片 - 移动端第1，桌面端左上向右下偏移 -->
        <div class="order-1 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-1 [@media(min-width:924px)]:row-start-1 [@media(min-width:924px)]:place-self-start [@media(min-width:924px)]:translate-y-4 welcome-card-offset">
          <GlassCard padding="medium" tilt={true} class="w-full max-w-[92vw] [@media(min-width:924px)]:max-w-sm">
            <div class="flex flex-col">
              <span class="inline-block px-3 py-1.5 bg-gradient-to-r from-purple-100/80 to-pink-100/80 rounded-full text-xs font-medium text-purple-700 mb-3 w-fit border border-purple-200/50 font-['Quicksand']">
                ✨ welcome to my world
              </span>
              <h2 class="text-3xl font-semibold bg-gradient-to-r from-purple-700 to-pink-600 bg-clip-text text-transparent mb-2 font-['Cormorant_Garamond'] italic">iqwqi's world</h2>
              <p class="text-sm text-gray-500 mb-4 font-['Quicksand'] font-light">explore · create · share</p>
              <div class="flex flex-wrap gap-3">
                <!-- 主按钮 - 优雅的渐变填充 -->
                <a href="/cs/" class="group inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-br from-purple-500/90 to-pink-500/90 text-white rounded-2xl font-medium text-sm tracking-wide hover:shadow-xl hover:shadow-purple-300/30 transition-all duration-300 hover:-translate-y-0.5 font-['Quicksand'] backdrop-blur-sm border border-white/20">
                  <span>enter</span>
                  <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                  </svg>
                </a>
                <!-- 次按钮 - 极简描边风格 -->
                <a href="/series/" class="group inline-flex items-center px-5 py-2.5 bg-white/40 text-purple-700 rounded-2xl font-medium text-sm tracking-wide hover:bg-white/60 hover:shadow-lg transition-all duration-300 border border-purple-200/50 font-['Quicksand']">
                  <span>series</span>
                  <svg class="w-3.5 h-3.5 ml-1.5 text-purple-400 group-hover:text-purple-600 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          </GlassCard>
        </div>

