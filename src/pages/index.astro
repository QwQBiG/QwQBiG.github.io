                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
                popular tags
              </h3>
              <div class="flex flex-wrap gap-1.5">
                {Array.from(new Set(regularPosts.flatMap(p => p.data.tags || []))).slice(0, 8).map((tag) => (
                  <a href={`/tags/${tag}/`} class="tag">
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          </GlassCard>
        </div>
        
        <!-- 音乐播放器 - 移动端第3，桌面端中下靠上偏右 -->
        <div class="order-3 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-2 [@media(min-width:924px)]:row-start-3 [@media(min-width:924px)]:place-self-start [@media(min-width:924px)]:self-center [@media(min-width:924px)]:translate-x-0 [@media(min-width:924px)]:-translate-y-8" style="position: relative; z-index: 50;">
          <GlassCard padding="small" tilt={true} class="w-full max-w-[95vw] [@media(min-width:924px)]:max-w-md [@media(min-width:924px)]:scale-95">
            <MusicWidget />
          </GlassCard>
        </div>
        
        <!-- 最新文章 - 移动端第9，桌面端右下靠左上 -->
        <div class="order-9 [@media(min-width:924px)]:order-none [@media(min-width:924px)]:col-start-3 [@media(min-width:924px)]:row-start-3 [@media(min-width:924px)]:place-self-start [@media(min-width:924px)]:self-start [@media(min-width:924px)]:-translate-x-8 [@media(min-width:924px)]:-translate-y-32">
          <GlassCard padding="medium" tilt={true} class="w-full max-w-[92vw] [@media(min-width:924px)]:max-w-xs [@media(min-width:924px)]:scale-95">
            <div class="flex flex-col h-full">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-semibold text-gray-700 flex items-center gap-2 font-['Cormorant_Garamond'] italic">
                  <svg class="w-4 h-4 text-purple-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  latest post
                </h3>
                <a href="/cs/" class="text-xs text-purple-600 hover:text-purple-700 font-['Quicksand']">all →</a>
              </div>
              {latestPosts.slice(0, 1).map((post) => (
                <a href={`/cs/${post.slug}/`} class="post-item block group flex-1">
                  <div class="flex flex-col h-full">
                    <h4 class="text-base font-semibold text-gray-800 group-hover:text-purple-600 transition-colors leading-snug mb-2">
                      {post.data.title}
                    </h4>
                    <p class="text-xs text-gray-500 line-clamp-2 mb-3 flex-1">
                      {post.data.description || 'No description'}
                    </p>
                    <div class="flex items-center justify-between pt-2 border-t border-gray-200/50">
                      <span class="text-[10px] text-gray-400">
                        {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                      </span>
                      <span class="text-[10px] text-purple-500 group-hover:translate-x-1 transition-transform font-['Quicksand']">
                        read →
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </GlassCard>
        </div>
        
      </div>
      <!-- /grid -->
      
    </div>
  </div>

  <!-- 视口高度修复 - 解决移动端地址栏导致的布局问题 -->
  <script is:inline>
    (function() {
      // 设置视口高度 CSS 变量
      function setVH() {
        const vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty('--vh', vh + 'px');
      }
      
      // 初始化并监听 resize
      setVH();
      window.addEventListener('resize', setVH);
      
      // 监听方向变化
      window.addEventListener('orientationchange', function() {
        setTimeout(setVH, 100);
      });
    })();
  </script>

  <!-- 环形文字交互脚本 -->
  <script is:inline>
    (function() {
      const ring = document.getElementById('interactiveRing');
      
      if (!ring) return;
      
      // 检测是否为触摸设备
      const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
      
      let isInteracting = false;
      let animationId = null;
      let currentRotateX = 0;
      let currentRotateY = 0;
      let targetRotateX = 0;
      let targetRotateY = 0;
      let lastUpdateTime = 0;
      
      // 平滑插值函数 - 触摸设备使用更快的响应
      function lerp(start, end, factor) {
        return start + (end - start) * factor;
      }
      
      // 更新环形文字的3D旋转 - 优化版本
      function updateRingTransform(timestamp) {
        // 节流：触摸设备每 16ms (60fps) 更新一次，非触摸设备可以更快
        const minInterval = isTouchDevice ? 16 : 8;
        if (timestamp - lastUpdateTime < minInterval) {
          animationId = requestAnimationFrame(updateRingTransform);
          return;
        }
        lastUpdateTime = timestamp;
        
        // 使用不同的插值因子：触摸设备更快响应
        const lerpFactor = isTouchDevice ? 0.15 : 0.1;
        currentRotateX = lerp(currentRotateX, targetRotateX, lerpFactor);
        currentRotateY = lerp(currentRotateY, targetRotateY, lerpFactor);
        
        // 批量设置样式，减少重排
        ring.style.cssText += `--rotateX: ${currentRotateX.toFixed(2)}deg; --rotateY: ${currentRotateY.toFixed(2)}deg; --translateZ: ${isInteracting ? '30px' : '0px'};`;
        
        animationId = requestAnimationFrame(updateRingTransform);
      }
      
      // 开始动画循环
      animationId = requestAnimationFrame(updateRingTransform);
      
      // 鼠标移动事件
      function handleMove(clientX, clientY) {
        const rect = ring.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        
        // 计算鼠标相对于环形中心的位置 (-1 到 1)
        const percentX = (clientX - centerX) / (rect.width / 2);
        const percentY = (clientY - centerY) / (rect.height / 2);
        
        // 限制范围
        const clampedX = Math.max(-1, Math.min(1, percentX));
        const clampedY = Math.max(-1, Math.min(1, percentY));
        
        // 设置目标旋转角度 (最大 ±15度)
        targetRotateY = clampedX * 15;
        targetRotateX = -clampedY * 15;
      }
      
      // 鼠标进入
      ring.addEventListener('mouseenter', function() {
        isInteracting = true;
        ring.classList.add('interacting');
      });
      
      // 鼠标移动
      ring.addEventListener('mousemove', function(e) {
        handleMove(e.clientX, e.clientY);
      });
      
      // 鼠标离开
      ring.addEventListener('mouseleave', function() {
        isInteracting = false;
        ring.classList.remove('interacting');
        targetRotateX = 0;
        targetRotateY = 0;
      });
      
      // 触摸事件支持
      ring.addEventListener('touchstart', function(e) {
        isInteracting = true;
        ring.classList.add('interacting');
        e.preventDefault();
      }, { passive: false });
      
      ring.addEventListener('touchmove', function(e) {
        if (e.touches.length > 0) {
          handleMove(e.touches[0].clientX, e.touches[0].clientY);
        }
        e.preventDefault();
      }, { passive: false });
      
      ring.addEventListener('touchend', function() {
        isInteracting = false;
        ring.classList.remove('interacting');
        targetRotateX = 0;
        targetRotateY = 0;
      });
      
      // 设备方向支持 (移动端)
      if (window.DeviceOrientationEvent) {
        window.addEventListener('deviceorientation', function(e) {
          if (!isInteracting && e.beta !== null && e.gamma !== null) {
            // beta: 前后倾斜 (-180 到 180), gamma: 左右倾斜 (-90 到 90)
            targetRotateX = Math.max(-15, Math.min(15, e.beta * 0.3));
            targetRotateY = Math.max(-15, Math.min(15, e.gamma * 0.3));
          }
        });
      }
    })();
    
    // 导航卡片优雅动效 - 点击任意链接时触发 - 优化版本
    (function() {
      const navCard = document.getElementById('navCard');
      const gridContainer = document.querySelector('.grid');
      
      if (!navCard) return;
      
      // 检测是否为触摸设备
      const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
      
      // 重置导航栏到卡片状态的函数
      function resetNavCardToCardState() {
        // 移除固定定位样式
        navCard.style.position = '';
        navCard.style.top = '';
        navCard.style.left = '';
        navCard.style.zIndex = '';
        
        // 恢复桌面端位移类
        navCard.classList.add('[@media(min-width:924px)]:translate-x-64', '[@media(min-width:924px)]:-translate-y-0');
        
        // 移除 GPU 加速和布局转换类
        navCard.classList.remove('gpu-accelerated', 'nav-card-layout-change');
        
        // 恢复其他元素的显示
        if (gridContainer) {
          const children = gridContainer.children;
          for (let i = 0; i < children.length; i++) {
            const child = children[i];
            if (child.id !== 'navCard') {
              child.style.willChange = '';
              child.style.transition = '';
              child.style.opacity = '';
              child.style.transform = '';
            }
          }
        }
      }
      
      // 页面可见性变化时重置导航栏（处理从其他页面返回的情况）
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'visible') {
          // 页面重新可见时，重置导航栏状态
          resetNavCardToCardState();
        }
      });
      
      // 页面加载时确保导航栏在正确位置
      window.addEventListener('pageshow', function(e) {
        // 如果是从缓存加载的页面（如浏览器返回），重置导航栏
        if (e.persisted) {
          resetNavCardToCardState();
        }
      });
      
      // 获取所有会跳转的链接
      const allLinks = document.querySelectorAll('a[href^="/"], a[href^="./"], a[href^="../"]');
      
      allLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          
          // 排除外部链接和锚点链接
          if (!href || href.startsWith('http') || href.startsWith('#')) return;
          
          e.preventDefault();
          
          // 使用 requestAnimationFrame 确保流畅的动画开始
          requestAnimationFrame(() => {
            // 直接设置固定定位到左上角
            navCard.style.position = 'fixed';
            navCard.style.top = '16px';
            navCard.style.left = '16px';
            navCard.style.zIndex = '9999';
            navCard.classList.remove('[@media(min-width:924px)]:translate-x-64', '[@media(min-width:924px)]:-translate-y-0');

            // 添加 GPU 加速类
            navCard.classList.add('gpu-accelerated');
            
            // 立即开始布局转换动画
            navCard.classList.add('nav-card-layout-change');
          });

          // 其他元素淡出（排除统计卡片）- 使用 requestAnimationFrame 批量处理
          if (gridContainer) {
            requestAnimationFrame(() => {
              const children = gridContainer.children;
              for (let i = 0; i < children.length; i++) {
                const child = children[i];
                const hasStats = child.querySelector('.stat-number');
                if (!hasStats && child.id !== 'navCard') {
                  child.style.willChange = 'opacity, transform';
                  child.style.transition = 'opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
                  child.style.opacity = '0';
                  child.style.transform = 'scale(0.97)';
                }
              }
            });
          }
          
          // 延迟跳转 - 移动端使用更短的延迟
          const delay = isTouchDevice ? 650 : 750;
          setTimeout(() => {
            window.location.href = href;
          }, delay);
        });
      });
    })();
  </script>
</body>
</html>
