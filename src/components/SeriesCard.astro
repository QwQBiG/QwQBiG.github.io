---
interface Props {
  title: string;
  description?: string;
  slug: string;
  postCount: number;
  collection?: string;
}

const { title, description, slug, postCount, collection = 'cs' } = Astro.props;
---

<a 
  href={`/${collection}/series/${slug}/`}
  class="group block bg-bg-secondary rounded-2xl p-6 border border-border-color hover:border-primary/30 transition-all duration-300 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-1"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="font-sans font-bold text-lg text-text-primary group-hover:text-primary transition-colors mb-2 line-clamp-1">
        {title}
      </h3>
      
      {description && (
        <p class="font-sans text-sm text-text-secondary line-clamp-2 mb-3">
          {description}
        </p>
      )}
      
      <div class="flex items-center gap-2 text-xs text-text-muted">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <span>{postCount} 篇文章</span>
      </div>
    </div>
    
    <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
      <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
      </svg>
    </div>
  </div>
</a>
