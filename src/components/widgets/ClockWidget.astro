---
// ClockWidget.astro - 重新设计的数字时钟组件
---

<div class="clock-widget w-full h-full flex flex-col items-center justify-center relative">
  <!-- 装饰性背景圆环 -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-24 h-24 md:w-28 md:h-28 rounded-full border border-white/20 opacity-50"></div>
    <div class="absolute w-20 h-20 md:w-24 md:h-24 rounded-full border border-white/10 opacity-30"></div>
  </div>
  
  <!-- 时间显示区域 -->
  <div class="time-display relative flex items-baseline gap-1 z-10">
    <span id="clock-time" class="clock-digits">00:00</span>
    <span id="clock-seconds" class="clock-seconds">:00</span>
  </div>
  
  <!-- 日期显示 -->
  <div id="clock-date" class="clock-date mt-2 md:mt-3 text-center px-2 z-10">
    Loading...
  </div>
  
  <!-- 装饰性指示点 -->
  <div class="flex gap-1.5 mt-3 z-10">
    <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-br from-purple-400 to-pink-400 opacity-80"></span>
    <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-br from-blue-400 to-cyan-400 opacity-60"></span>
    <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-br from-amber-400 to-orange-400 opacity-40"></span>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Inter:wght@400;500;600&display=swap');

  .clock-widget {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    /* 禁用光标和选择 */
    caret-color: transparent;
    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
  }
  
  .time-display {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  
  .clock-digits {
    font-size: clamp(1.75rem, 8vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    /* 紫粉渐变文字效果 */
    background: linear-gradient(
      135deg,
      #8B5CF6 0%,
      #EC4899 50%,
      #F472B6 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    /* 微妙的文字阴影增加深度 */
    filter: drop-shadow(0 2px 4px rgba(139, 92, 246, 0.2));
    line-height: 1;
    white-space: nowrap;
  }

  .clock-seconds {
    font-size: clamp(0.875rem, 4vw, 1.5rem);
    font-weight: 400;
    /* 蓝青渐变 */
    background: linear-gradient(
      135deg,
      #3B82F6 0%,
      #06B6D4 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    opacity: 0.9;
  }

  .clock-date {
    font-family: 'Inter', sans-serif;
    font-size: clamp(0.65rem, 3vw, 0.875rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    /* 深灰紫色调 */
    color: rgba(107, 114, 128, 0.9);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  
  /* 深色模式适配 - 已禁用 */
  /* @media (prefers-color-scheme: dark) { ... } */
  
  /* 秒数闪烁动画 */
  @keyframes pulse-soft {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 0.5; }
  }
  
  .clock-seconds {
    animation: pulse-soft 2s ease-in-out infinite;
  }
</style>

<script>
  function updateClock() {
    const now = new Date();
    
    // 格式化时间
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    
    // 更新 DOM
    const timeEl = document.getElementById('clock-time');
    const secondsEl = document.getElementById('clock-seconds');
    const dateEl = document.getElementById('clock-date');
    
    if (timeEl) timeEl.textContent = `${hours}:${minutes}`;
    if (secondsEl) secondsEl.textContent = `:${seconds}`;
    
    if (dateEl) {
      const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const weekday = weekdays[now.getDay()];
      const month = months[now.getMonth()];
      const day = String(now.getDate()).padStart(2, '0');
      dateEl.textContent = `${weekday}, ${month} ${day}`;
    }
  }
  
  // 立即执行一次
  updateClock();
  
  // 每秒更新
  setInterval(updateClock, 1000);
  
  // Astro ViewTransitions 兼容
  document.addEventListener('astro:page-load', updateClock);
</script>
