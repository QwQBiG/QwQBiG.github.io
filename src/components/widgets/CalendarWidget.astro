---
// CalendarWidget.astro - 优化版迷你日历组件
---

<div class="calendar-widget w-full h-full flex flex-col" style="position: relative; z-index: 50;">
  <!-- 月份标题 -->
  <div class="calendar-header flex items-center justify-between mb-2 md:mb-3" style="position: relative; z-index: 51;">
    <button id="prev-month" class="calendar-nav-btn p-1.5 rounded-lg hover:bg-white/50 transition-colors flex-shrink-0" style="position: relative; z-index: 100; pointer-events: auto; cursor: pointer;" type="button">
      <svg class="w-3 h-3 md:w-4 md:h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>
    <span id="calendar-month-year" class="calendar-title text-xs md:text-sm font-semibold tracking-wide text-center flex-1 px-1 truncate"></span>
    <button id="next-month" class="calendar-nav-btn p-1.5 rounded-lg hover:bg-white/50 transition-colors flex-shrink-0" style="position: relative; z-index: 100; pointer-events: auto; cursor: pointer;" type="button">
      <svg class="w-3 h-3 md:w-4 md:h-4 text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>
  
  <!-- 星期标题 -->
  <div class="calendar-weekdays grid grid-cols-7 gap-0.5 md:gap-1 mb-1 md:mb-2">
    {['M', 'T', 'W', 'T', 'F', 'S', 'S'].map((day) => (
      <div class="calendar-weekday text-center text-[10px] md:text-xs font-medium py-0.5 font-['Cormorant_Garamond']">
        {day}
      </div>
    ))}
  </div>
  
  <!-- 日期网格 -->
  <div id="calendar-days" class="calendar-days grid grid-cols-7 gap-0.5 md:gap-1 flex-1">
    <!-- 由 JS 动态生成 -->
  </div>
</div>

<style is:global>
  /* 日历组件样式 - 使用 is:global 确保动态生成的元素也能应用样式 */
  .calendar-widget {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    /* 禁用光标和选择 */
    caret-color: transparent;
    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
  }
  
  .calendar-nav-btn {
    transition: all 0.2s ease;
  }
  
  .calendar-nav-btn:hover {
    background: rgba(255, 255, 255, 0.6);
    transform: scale(1.05);
  }
  
  .calendar-nav-btn:active {
    transform: scale(0.95);
  }
  
  /* 月份标题 - 紫粉渐变 */
  .calendar-title {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.9) 0%, rgba(236, 72, 153, 0.85) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  /* 星期标题 - 柔和的紫灰色 */
  .calendar-weekday {
    color: rgba(139, 92, 246, 0.5);
    font-weight: 600;
  }
  
  .calendar-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.65rem, 1.5vw, 0.85rem);
    font-weight: 600;
    /* 本月日期 - 使用与时钟日期相同的灰色 */
    color: rgba(107, 114, 128, 0.9);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    min-height: 1.5rem;
    min-width: 1.5rem;
  }
  
  .calendar-day:hover:not(.today):not(.other-month) {
    background: rgba(255, 255, 255, 0.7);
    transform: scale(1.1);
    box-shadow: 0 2px 8px rgba(139, 92, 246, 0.15);
  }
  
  /* 非本月日期 - 极淡的灰色，几乎看不见 */
  .calendar-day.other-month {
    color: rgba(156, 163, 175, 0.25) !important;
    cursor: default;
    font-weight: 400;
  }
  
  .calendar-day.other-month:hover {
    background: transparent;
    transform: none;
    box-shadow: none;
  }
  
  /* 周末日期 - 淡紫色 */
  .calendar-day.weekend {
    color: rgba(139, 92, 246, 0.75) !important;
    font-weight: 600;
  }
  
  /* 今天的特殊样式 - 紫粉渐变，更精致 */
  .calendar-day.today {
    background: linear-gradient(135deg, #a78bfa 0%, #f472b6 100%) !important;
    color: white !important;
    font-weight: 600;
    box-shadow: 
      0 3px 10px rgba(167, 139, 250, 0.35),
      inset 0 1px 1px rgba(255, 255, 255, 0.4);
    transform: translateY(-1px);
  }
  
  .calendar-day.today:hover {
    transform: translateY(-1px) scale(1.08);
    box-shadow: 
      0 5px 14px rgba(167, 139, 250, 0.45),
      inset 0 1px 1px rgba(255, 255, 255, 0.4);
  }
  
  /* 深色模式适配 */
  @media (prefers-color-scheme: dark) {
    .calendar-title {
      background: linear-gradient(135deg, rgba(196, 181, 253, 0.95) 0%, rgba(244, 114, 182, 0.9) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .calendar-weekday {
      color: rgba(167, 139, 250, 0.6);
    }
    
    .calendar-day {
      /* 深色模式下本月日期 - 使用与时钟日期相同的灰色 */
      color: rgba(156, 163, 175, 0.9);
    }
    
    .calendar-day.other-month {
      color: rgba(107, 114, 128, 0.2) !important;
    }
    
    .calendar-day.weekend {
      color: rgba(167, 139, 250, 0.85) !important;
    }
    
    .calendar-day:hover:not(.today):not(.other-month) {
      background: rgba(255, 255, 255, 0.1);
    }
  }
</style>

<script>
  class CalendarWidget {
    constructor() {
      this.currentDate = new Date();
      this.today = new Date();
      this.monthYearEl = document.getElementById('calendar-month-year');
      this.daysContainer = document.getElementById('calendar-days');
      this.prevBtn = document.getElementById('prev-month');
      this.nextBtn = document.getElementById('next-month');
      
      this.init();
    }
    
    init() {
      this.render();
      this.bindEvents();
    }
    
    bindEvents() {
      // 限制在当年范围内（当前年份的前后6个月）
      const currentYear = this.today.getFullYear();
      const minDate = new Date(currentYear, 0, 1); // 当年1月
      const maxDate = new Date(currentYear, 11, 31); // 当年12月
      
      // 使用箭头函数绑定到实例
      const self = this;
      
      if (this.prevBtn) {
        // 直接设置 onclick 属性，绕过事件冒泡
        this.prevBtn.onclick = function(e) {
          if (e) e.stopPropagation();
          const newDate = new Date(self.currentDate);
          newDate.setMonth(newDate.getMonth() - 1);
          // 限制不能早于当年1月
          if (newDate >= minDate) {
            self.currentDate = newDate;
            self.render();
          }
          return false;
        };
      }
      
      if (this.nextBtn) {
        // 直接设置 onclick 属性，绕过事件冒泡
        this.nextBtn.onclick = function(e) {
          if (e) e.stopPropagation();
          const newDate = new Date(self.currentDate);
          newDate.setMonth(newDate.getMonth() + 1);
          // 限制不能晚于当年12月
          if (newDate <= maxDate) {
            self.currentDate = newDate;
            self.render();
          }
          return false;
        };
      }
    }
    
    render() {
      const year = this.currentDate.getFullYear();
      const month = this.currentDate.getMonth();
      const currentYear = this.today.getFullYear();
      
      // 更新月份标题
      const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      if (this.monthYearEl) {
        this.monthYearEl.textContent = `${monthNames[month]} ${year}`;
      }
      
      // 更新按钮状态（当年范围内可翻页）
      if (this.prevBtn) {
        const isFirstMonth = year === currentYear && month === 0;
        this.prevBtn.style.opacity = isFirstMonth ? '0.3' : '1';
        this.prevBtn.style.cursor = isFirstMonth ? 'not-allowed' : 'pointer';
      }
      
      if (this.nextBtn) {
        const isLastMonth = year === currentYear && month === 11;
        this.nextBtn.style.opacity = isLastMonth ? '0.3' : '1';
        this.nextBtn.style.cursor = isLastMonth ? 'not-allowed' : 'pointer';
      }
      
      // 获取当月第一天和最后一天
      const firstDay = new Date(year, month, 1);
      const lastDay = new Date(year, month + 1, 0);
      const daysInMonth = lastDay.getDate();
      
      // 获取第一天是星期几 (0=周日, 1=周一...)
      let startingDay = firstDay.getDay();
      // 调整为周一开始 (0=周一, 6=周日)
      startingDay = startingDay === 0 ? 6 : startingDay - 1;
      
      // 获取上个月的天数
      const prevMonthLastDay = new Date(year, month, 0).getDate();
      
      let html = '';
      
      // 上个月的日期
      for (let i = startingDay - 1; i >= 0; i--) {
        const day = prevMonthLastDay - i;
        html += `<div class="calendar-day other-month">${day}</div>`;
      }
      
      // 当月的日期
      for (let day = 1; day <= daysInMonth; day++) {
        const isToday = 
          day === this.today.getDate() && 
          month === this.today.getMonth() && 
          year === this.today.getFullYear();
        
        // 判断是否是周末
        const date = new Date(year, month, day);
        const dayOfWeek = date.getDay();
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
        
        let className = 'calendar-day';
        if (isToday) {
          className += ' today';
        } else if (isWeekend) {
          className += ' weekend';
        }
        
        html += `<div class="${className}">${day}</div>`;
      }
      
      // 下个月的日期（填充剩余格子）
      const totalCells = Math.ceil((startingDay + daysInMonth) / 7) * 7;
      const remainingCells = totalCells - (startingDay + daysInMonth);
      
      for (let day = 1; day <= remainingCells; day++) {
        html += `<div class="calendar-day other-month">${day}</div>`;
      }
      
      if (this.daysContainer) {
        this.daysContainer.innerHTML = html;
      }
    }
  }
  
  // 初始化日历
  function initCalendar() {
    new CalendarWidget();
  }
  
  // 页面加载时初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalendar);
  } else {
    initCalendar();
  }
  
  // Astro ViewTransitions 兼容
  document.addEventListener('astro:page-load', initCalendar);
</script>
