---
// MusicWidget.astro - 横向条形音乐播放器（适配毛玻璃风格）
---

<div class="music-bar w-full h-full flex items-center gap-2 md:gap-3 px-1" style="position: relative; z-index: 200; pointer-events: auto;">
  <!-- 播放/暂停按钮 - 使用最高z-index确保在最上层 -->
  <button id="play-btn" class="play-btn flex-shrink-0 w-10 h-10 md:w-11 md:h-11 rounded-full flex items-center justify-center" style="position: relative; z-index: 9999; pointer-events: auto; cursor: pointer;">
    <svg id="play-icon" class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
      <path d="M8 5v14l11-7z"/>
    </svg>
    <svg id="pause-icon" class="w-5 h-5 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
      <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
    </svg>
  </button>

  <!-- 歌曲信息 + 进度条区域 -->
  <div class="flex-[5] min-w-0 flex flex-col justify-center gap-1.5 md:gap-2">
    <!-- 歌曲信息 -->
    <div class="flex items-center justify-between min-w-0 gap-1 md:gap-2">
      <div class="flex items-center gap-2 min-w-0 overflow-hidden flex-1">
        <!-- 频谱动画 -->
        <div id="playing-indicator" class="flex gap-0.5 items-end h-3 opacity-0 transition-opacity flex-shrink-0">
          <span class="w-0.5 bg-gradient-to-t from-purple-500 to-pink-400 rounded-full animate-bar-1"></span>
          <span class="w-0.5 bg-gradient-to-t from-purple-500 to-pink-400 rounded-full animate-bar-2"></span>
          <span class="w-0.5 bg-gradient-to-t from-purple-500 to-pink-400 rounded-full animate-bar-3"></span>
        </div>
        <!-- 滚动歌曲信息容器 -->
        <div class="track-scroll-container overflow-hidden flex-1">
          <div class="track-scroll-content">
            <span class="track-name text-xs md:text-base font-semibold">world.execute(me)</span>
            <span class="text-gray-400/50 mx-1">·</span>
            <span class="artist-name text-[10px] md:text-sm">Neuro</span>
            <!-- 复制一份用于无缝循环 -->
            <span class="track-name duplicate text-xs md:text-base font-semibold ml-8">world.execute(me)</span>
            <span class="text-gray-400/50 duplicate mx-1">·</span>
            <span class="artist-name duplicate text-[10px] md:text-sm">Neuro</span>
          </div>
        </div>
      </div>
      <span id="time-display" class="time-display text-[10px] md:text-sm font-mono flex-shrink-0">0:00 / 0:00</span>
    </div>

    <!-- 进度条 -->
    <div class="progress-wrapper relative h-5 flex items-center cursor-pointer" id="progress-container" style="pointer-events: auto; z-index: 101;">
      <div class="progress-track w-full h-1.5 md:h-2 rounded-full overflow-hidden">
        <div id="progress-fill" class="progress-fill h-full rounded-full" style="width: 0%"></div>
      </div>
      <!-- 进度滑块 -->
      <div id="progress-thumb" class="progress-thumb absolute w-3 h-3 md:w-3.5 md:h-3.5 rounded-full shadow-md" style="left: 0%"></div>
    </div>
  </div>

  <!-- 音量控制 + 切歌按钮 -->
  <div class="flex items-center gap-1 flex-shrink-0">
    <button id="volume-btn" class="volume-btn p-1 rounded-full hover:bg-white/50 transition-colors" title="静音/取消静音">
      <!-- 有音量图标 -->
      <svg id="volume-on-icon" class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
      </svg>
      <!-- 静音图标 -->
      <svg id="volume-off-icon" class="w-4 h-4 text-gray-500 hidden" fill="currentColor" viewBox="0 0 24 24">
        <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73 4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
      </svg>
    </button>
    <button id="prev-btn" class="nav-btn p-1 rounded-full hover:bg-white/50 transition-colors">
      <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/>
      </svg>
    </button>
    <button id="next-btn" class="nav-btn p-1 rounded-full hover:bg-white/50 transition-colors">
      <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
      </svg>
    </button>
  </div>
</div>

<audio id="audio-player" preload="auto" class="hidden" crossorigin="anonymous">
  <source src="/music/world.execute(me);[Neuro].aac" type="audio/aac">
  Your browser does not support the audio element.
</audio>

<style>
  .music-bar {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    /* 禁用光标和选择 */
    caret-color: transparent;
    user-select: none;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
  }

  /* 播放按钮 - 很浅的紫粉渐变 */
  .play-btn {
    background: linear-gradient(135deg, #ddd6fe 0%, #fbcfe8 100%);
    box-shadow:
      0 4px 12px rgba(221, 214, 254, 0.35),
      inset 0 1px 2px rgba(255, 255, 255, 0.6);
    transition: all 0.2s ease;
  }

  .play-btn:hover {
    transform: scale(1.08);
    box-shadow:
      0 6px 16px rgba(221, 214, 254, 0.45),
      inset 0 1px 2px rgba(255, 255, 255, 0.6);
  }

  .play-btn:active {
    transform: scale(0.96);
  }

  /* 歌曲名称 - 深紫灰色，与毛玻璃协调 */
  .track-name {
    color: rgba(88, 28, 135, 0.9);
    background: linear-gradient(135deg, rgba(88, 28, 135, 0.9) 0%, rgba(126, 34, 206, 0.85) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* 艺术家名称 - 柔和的灰色 */
  .artist-name {
    color: rgba(107, 114, 128, 0.75);
  }

  /* 歌曲信息滚动容器 */
  .track-scroll-container {
    position: relative;
  }

  .track-scroll-content {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    padding-right: 1rem;
  }

  /* 不滚动时隐藏复制的第二份内容 */
  .track-scroll-container:not(.can-scroll) .duplicate {
    display: none;
  }

  /* 只在文字溢出时显示遮罩和滚动动画 */
  .track-scroll-container.can-scroll {
    mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
  }

  .track-scroll-container.can-scroll .track-scroll-content {
    animation: scroll-text 12s linear infinite;
  }

  /* 当鼠标悬停时暂停滚动 */
  .track-scroll-container.can-scroll:hover .track-scroll-content {
    animation-play-state: paused;
  }

  @keyframes scroll-text {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(var(--scroll-distance, -100%));
    }
  }

  /* 时间显示 - 紫色调 */
  .time-display {
    color: rgba(139, 92, 246, 0.7);
    letter-spacing: 0.02em;
  }

  /* 频谱动画 */
  @keyframes bar1 {
    0%, 100% { height: 4px; }
    50% { height: 12px; }
  }

  @keyframes bar2 {
    0%, 100% { height: 10px; }
    50% { height: 4px; }
  }

  @keyframes bar3 {
    0%, 100% { height: 6px; }
    50% { height: 12px; }
  }

  .animate-bar-1 {
    animation: bar1 0.6s ease-in-out infinite;
    height: 4px;
  }

  .animate-bar-2 {
    animation: bar2 0.5s ease-in-out infinite;
    height: 10px;
  }

  .animate-bar-3 {
    animation: bar3 0.7s ease-in-out infinite;
    height: 6px;
  }

  /* 进度条轨道 - 更柔和的灰色 */
  .progress-track {
    background: rgba(0, 0, 0, 0.06);
    box-shadow: inset 1px 1px 2px rgba(0, 0, 0, 0.08);
  }

  .progress-fill {
    background: linear-gradient(90deg, #c4b5fd 0%, #ddd6fe 30%, #f9a8d4 70%, #fbcfe8 100%);
    transition: width 0.1s linear;
  }

  .progress-thumb {
    transform: translateX(-50%);
    transition: left 0.1s linear, transform 0.2s ease;
    box-shadow:
      0 2px 6px rgba(0, 0, 0, 0.1),
      0 0 0 2px rgba(255, 255, 255, 0.9);
    background: linear-gradient(135deg, #ffffff 0%, #faf5ff 100%);
    border: 2px solid rgba(221, 214, 254, 0.5);
  }

  .progress-wrapper:hover .progress-thumb {
    transform: translateX(-50%) scale(1.15);
    border-color: rgba(221, 214, 254, 0.8);
  }

  /* 导航按钮 */
  .nav-btn {
    transition: all 0.2s ease;
  }

  .nav-btn:hover {
    background: rgba(255, 255, 255, 0.6);
    transform: scale(1.05);
  }

  .nav-btn:active {
    transform: scale(0.95);
  }

  /* 音量滑块 */
  .volume-slider {
    background: rgba(0, 0, 0, 0.06);
    box-shadow: inset 1px 1px 2px rgba(0, 0, 0, 0.08);
  }

  .volume-fill {
    background: linear-gradient(90deg, #a78bfa 0%, #f472b6 100%);
  }

  /* 深色模式适配 */
  @media (prefers-color-scheme: dark) {
    .track-name {
      background: linear-gradient(135deg, rgba(196, 181, 253, 0.95) 0%, rgba(244, 114, 182, 0.9) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .artist-name {
      color: rgba(156, 163, 175, 0.7);
    }

    .time-display {
      color: rgba(167, 139, 250, 0.8);
    }

    .progress-track {
      background: rgba(255, 255, 255, 0.1);
    }

    .progress-thumb {
      background: linear-gradient(135deg, #4b5563 0%, #374151 100%);
      border-color: rgba(167, 139, 250, 0.5);
      box-shadow:
        0 2px 6px rgba(0, 0, 0, 0.3),
        0 0 0 2px rgba(55, 65, 81, 0.8);
    }

    .volume-slider {
      background: rgba(255, 255, 255, 0.1);
    }
  }
</style>

<script>
  (function() {
    'use strict';

    var isInitialized = false;
    var isPlaying = false;
    var volume = 70;
    var isMuted = false;

    var audio, playBtn, progressFill, progressThumb;
    var progressContainer, timeDisplay;
    var volumeBtn, volumeSlider, volumeFill, prevBtn, nextBtn;

    function getElements() {
      audio = document.getElementById('audio-player');
      playBtn = document.getElementById('play-btn');
      progressFill = document.getElementById('progress-fill');
      progressThumb = document.getElementById('progress-thumb');
      progressContainer = document.getElementById('progress-container');
      timeDisplay = document.getElementById('time-display');
      volumeBtn = document.getElementById('volume-btn');
      volumeSlider = document.querySelector('.volume-slider');
      volumeFill = document.querySelector('.volume-fill');
      prevBtn = document.getElementById('prev-btn');
      nextBtn = document.getElementById('next-btn');

      return !!(audio && playBtn);
    }

    // 检测文字是否溢出，决定是否启用滚动
    function checkTextOverflow() {
      var scrollContainer = document.querySelector('.track-scroll-container');
      var scrollContent = document.querySelector('.track-scroll-content');
      if (!scrollContainer || !scrollContent) return;

      // 比较内容宽度和容器宽度
      // 由于内容复制了一份，实际内容宽度是 scrollWidth 的一半
      var containerWidth = scrollContainer.clientWidth;
      var contentWidth = scrollContent.scrollWidth / 2; // 只取一半（原始内容）

      if (contentWidth > containerWidth + 5) {
        // 文字溢出，启用滚动
        scrollContainer.classList.add('can-scroll');
        // 设置 CSS 变量用于动画 - 只滚动原始内容的宽度
        var scrollDistance = -(contentWidth + 10);
        scrollContainer.style.setProperty('--scroll-distance', scrollDistance + 'px');
      } else {
        // 文字未溢出，禁用滚动
        scrollContainer.classList.remove('can-scroll');
      }
    }

    function updateIcons() {
      var playIcon = document.getElementById('play-icon');
      var pauseIcon = document.getElementById('pause-icon');
      var indicator = document.getElementById('playing-indicator');

      if (isPlaying) {
        if (playIcon) playIcon.classList.add('hidden');
        if (pauseIcon) pauseIcon.classList.remove('hidden');
        if (indicator) indicator.classList.remove('opacity-0');
      } else {
        if (playIcon) playIcon.classList.remove('hidden');
        if (pauseIcon) pauseIcon.classList.add('hidden');
        if (indicator) indicator.classList.add('opacity-0');
      }
    }

    function formatTime(seconds) {
      if (!seconds || isNaN(seconds)) return '0:00';
      var mins = Math.floor(seconds / 60);
      var secs = Math.floor(seconds % 60);
      return mins + ':' + (secs < 10 ? '0' : '') + secs;
    }

    function updateProgress() {
      if (!audio || !audio.duration || !progressFill || !progressThumb || !timeDisplay) return;

      var percent = (audio.currentTime / audio.duration) * 100;
      progressFill.style.width = percent + '%';
      progressThumb.style.left = percent + '%';
      timeDisplay.textContent = formatTime(audio.currentTime) + ' / ' + formatTime(audio.duration);
    }

    function togglePlay(e) {
      if (e) {
        e.preventDefault();
        e.stopPropagation();
      }

      if (!audio) return;

      if (isPlaying) {
        audio.pause();
        isPlaying = false;
        updateIcons();
      } else {
        var playPromise = audio.play();
        if (playPromise !== undefined) {
          playPromise.then(function() {
            isPlaying = true;
            updateIcons();
          });
        }
      }
    }

    function init() {
      if (isInitialized) return true;
      if (!getElements()) return false;

      audio.volume = 0.7;

      playBtn.addEventListener('click', togglePlay);

      audio.addEventListener('loadedmetadata', updateProgress);
      audio.addEventListener('timeupdate', updateProgress);
      audio.addEventListener('ended', function() {
        isPlaying = false;
        updateIcons();
      });

      if (progressContainer) {
        progressContainer.addEventListener('click', function(e) {
          if (!audio || !audio.duration) return;
          var rect = progressContainer.getBoundingClientRect();
          var percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          audio.currentTime = percent * audio.duration;
        });
      }

      if (volumeBtn) {
        volumeBtn.addEventListener('click', function() {
          isMuted = !isMuted;
          audio.muted = isMuted;
          updateVolumeIcon();
        });
      }

      // 更新音量图标
      function updateVolumeIcon() {
        var volumeOnIcon = document.getElementById('volume-on-icon');
        var volumeOffIcon = document.getElementById('volume-off-icon');
        if (volumeOnIcon && volumeOffIcon) {
          if (isMuted) {
            volumeOnIcon.classList.add('hidden');
            volumeOffIcon.classList.remove('hidden');
          } else {
            volumeOnIcon.classList.remove('hidden');
            volumeOffIcon.classList.add('hidden');
          }
        }
      }

      if (volumeSlider) {
        volumeSlider.addEventListener('click', function(e) {
          var rect = volumeSlider.getBoundingClientRect();
          var percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          volume = Math.round(percent * 100);
          audio.volume = percent;
          audio.muted = volume === 0;
          if (volumeFill) volumeFill.style.width = volume + '%';
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          audio.currentTime = 0;
          if (isPlaying) audio.play();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          audio.currentTime = 0;
          if (isPlaying) audio.play();
        });
      }

      // 初始化时检测文字溢出
      checkTextOverflow();

      // 窗口大小变化时重新检测
      window.addEventListener('resize', checkTextOverflow);

      isInitialized = true;
      return true;
    }

    init();

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    }

    document.addEventListener('astro:page-load', function() {
      isInitialized = false;
      init();
    });

  })();
</script>
